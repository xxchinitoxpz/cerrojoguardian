<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="48dp"
    android:background="@color/dark_gray"
    android:gravity="center">

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Configura tu clave secreta"
        android:textSize="28sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ingresa 4 dígitos"
        android:textSize="20sp"
        android:textColor="@color/teal_200"
        android:layout_marginBottom="32dp"
        android:gravity="center" />

    <!-- Display del código -->
    <TextView
        android:id="@+id/codeDisplay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="_ _ _ _"
        android:textSize="48sp"
        android:textColor="@color/orange"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginBottom="48dp"
        android:minHeight="80dp"
        android:gravity="center" />

    <!-- Teclado numérico -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Fila 1: 1, 2, 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnNum1"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="1"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:layout_marginEnd="12dp"
                android:background="@drawable/button_number" />

            <Button
                android:id="@+id/btnNum2"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="2"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:layout_marginEnd="12dp"
                android:background="@drawable/button_number" />

            <Button
                android:id="@+id/btnNum3"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="3"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:background="@drawable/button_number" />
        </LinearLayout>

        <!-- Fila 2: 4, 5, 6 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnNum4"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="4"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:layout_marginEnd="12dp"
                android:background="@drawable/button_number" />

            <Button
                android:id="@+id/btnNum5"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="5"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:layout_marginEnd="12dp"
                android:background="@drawable/button_number" />

            <Button
                android:id="@+id/btnNum6"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="6"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:background="@drawable/button_number" />
        </LinearLayout>

        <!-- Fila 3: 7, 8, 9 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnNum7"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="7"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:layout_marginEnd="12dp"
                android:background="@drawable/button_number" />

            <Button
                android:id="@+id/btnNum8"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="8"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:layout_marginEnd="12dp"
                android:background="@drawable/button_number" />

            <Button
                android:id="@+id/btnNum9"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="9"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:background="@drawable/button_number" />
        </LinearLayout>

        <!-- Fila 4: Borrar, 0, Confirmar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="⌫"
                android:textSize="24sp"
                android:textColor="@color/white"
                android:layout_marginEnd="12dp"
                android:background="@drawable/button_operator" />

            <Button
                android:id="@+id/btnNum0"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="0"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:layout_marginEnd="12dp"
                android:background="@drawable/button_number" />

            <Button
                android:id="@+id/btnConfirm"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="✓"
                android:textSize="28sp"
                android:textColor="@color/white"
                android:background="@drawable/button_operator" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>

